<!-- BlueThink Mobile — robot only (no scene elements).
     Use this file when attaching to an external scene (e.g. 3DGS). -->
<mujoco model="BlueThink">
  <compiler angle="radian" autolimits="true" meshdir="./"/>

  <option timestep="0.002" gravity="0 0 -9.81" iterations="30" solver="Newton"/>

  <default>
    <default class="bluethink">
      <material specular="0.5" shininess="0.25"/>
      <joint armature="0.08" damping="4.0" frictionloss="0.1"/>
      <general dyntype="none" biastype="affine"/>
      <default class="visual">
        <geom type="mesh" contype="0" conaffinity="0" group="2"/>
      </default>
      <default class="collision">
        <geom type="mesh" group="3"/>
      </default>
    </default>
    <!-- Base wheel defaults -->
    <joint armature="0.1" damping="2.0" frictionloss="0.01"/>
    <default class="base_visual">
      <geom type="mesh" contype="0" conaffinity="0" group="1"/>
    </default>
    <default class="wheel_collision">
      <geom type="mesh" group="3" condim="3" friction="1.2 0.005 0.0001"
            contype="1" conaffinity="1"/>
    </default>
  </default>

