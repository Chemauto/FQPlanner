    <exclude body1="Base_Link" body2="Left_Shoulder_Pitch_Link"/>
    <exclude body1="Base_Link" body2="Right_Shoulder_Pitch_Link"/>
    <exclude body1="Left_Shoulder_Pitch_Link" body2="Left_Shoulder_Roll_Link"/>
