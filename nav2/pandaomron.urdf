<?xml version="1.0"?>
<robot name="pandaomron_base" xmlns:xacro="http://www.ros.org/wiki/xacro">

  <!-- Omron 移动底盘 URDF（仅底盘，用于 Nav2 tf 树和 ros2_control） -->

  <link name="odom"/>

  <link name="base_footprint"/>

  <link name="base_link">
    <visual>
      <origin xyz="0 0 0.096" rpy="0 0 0"/>
      <geometry>
        <box size="0.70 0.50 0.19"/>
      </geometry>
      <material name="grey">
        <color rgba="0.5 0.5 0.5 1"/>
      </material>
    </visual>
    <collision>
      <origin xyz="0 0 0.096" rpy="0 0 0"/>
      <geometry>
        <box size="0.70 0.50 0.19"/>
      </geometry>
    </collision>
    <inertial>
      <mass value="60"/>
      <origin xyz="0 0 0.096" rpy="0 0 0"/>
      <inertia ixx="2.0" ixy="0" ixz="0" iyy="2.0" iyz="0" izz="3.0"/>
    </inertial>
  </link>

  <!-- odom → base_footprint（由桥接节点发布） -->
  <joint name="odom_to_base_footprint" type="fixed">
    <parent link="odom"/>
    <child link="base_footprint"/>
    <origin xyz="0 0 0" rpy="0 0 0"/>
  </joint>

  <!-- base_footprint → base_link -->
  <joint name="base_footprint_to_base_link" type="fixed">
    <parent link="base_footprint"/>
    <child link="base_link"/>
    <origin xyz="0 0 0.192" rpy="0 0 0"/>
  </joint>

  <!-- 传感器模型（可选，Nav2 可能需要） -->
  <link name="laser_link">
    <visual>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <geometry>
        <cylinder radius="0.04" length="0.06"/>
      </geometry>
      <material name="black">
        <color rgba="0.1 0.1 0.1 1"/>
      </material>
    </visual>
  </link>

  <joint name="laser_joint" type="fixed">
    <parent link="base_link"/>
    <child link="laser_link"/>
    <origin xyz="0.25 0 0.15" rpy="0 0 0"/>
  </joint>

</robot>
